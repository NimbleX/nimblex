#!/bin/bash
# Only run ldconfig if any bundle's ld.so.cache is newer than /etc/ld.so.cache.
# On a live system, bundles are squashfs modules mounted at /mnt/live/memory/bundles/.
# If no bundle has a newer cache, the existing one is already valid.

CACHE=/etc/ld.so.cache

# If no cache exists yet, always rebuild
[[ -f "$CACHE" ]] || exec /sbin/ldconfig -X

for bundle_cache in /mnt/live/memory/bundles/*/etc/ld.so.cache; do
    if [[ -f "$bundle_cache" ]] && [[ "$bundle_cache" -nt "$CACHE" ]]; then
        exec /sbin/ldconfig -X
    fi
done

exit 0
