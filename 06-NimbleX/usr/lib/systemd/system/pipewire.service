[Unit]
Description=PipeWire Multimedia System
Wants=pipewire.socket avahi-daemon.service
After=avahi-daemon.service dbus.service

[Service]
Type=simple
ExecStart=/usr/bin/pipewire
Restart=on-failure
RestartSec=5
User=pipewire
RuntimeDirectory=pipewire
Environment=PIPEWIRE_RUNTIME_DIR=/run/pipewire

[Install]
WantedBy=multi-user.target
Also=wireplumber.service
